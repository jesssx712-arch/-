<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pong Game</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>PONG GAME</h1>
        <div class="scoreboard">
            <div class="score">
                <span class="label">Player</span>
                <span class="score-value" id="playerScore">0</span>
            </div>
            <div class="divider">-</div>
            <div class="score">
                <span class="label">AI</span>
                <span class="score-value" id="aiScore">0</span>
            </div>
        </div>
        
        <canvas id="gameCanvas"></canvas>
        
        <div class="instructions">
            <p><strong>Controls:</strong></p>
            <p>🖱️ Mouse Y Position - Move Left Paddle</p>
            <p>⬆️ Arrow Up / W - Move Left Paddle Up</p>
            <p>⬇️ Arrow Down / S - Move Left Paddle Down</p>
            <p>Right paddle is controlled by AI</p>
            <button id="resetBtn">Reset Game</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
